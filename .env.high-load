# =============================================================================
# HIGH-LOAD PROFILE — Para soportar ~1000 chats/hora
# =============================================================================
# Uso: docker compose --env-file .env --env-file .env.high-load up -d
# O cambiar a este perfil en docker-compose.yml (profiles)
#
# Este archivo SOLO sobreescribe los valores de scaling.
# Todos los demas valores (Bird, OpenAI, DB credentials) vienen de .env
# =============================================================================

# Profile identifier (used by capacity monitor for alert messages)
SCALING_PROFILE=high-load

# Worker Pool — 5x mas workers y buffer
WORKER_POOL_SIZE=50
WORKER_QUEUE_SIZE=500

# Local DB (neuro_bot) — conexiones para sessions, tracking, inbox
LOCAL_DB_MAX_OPEN=50
LOCAL_DB_MAX_IDLE=25

# External DB (datosipsndx) — conexiones para citas, doctores, agendas
EXTERNAL_DB_MAX_OPEN=50
EXTERNAL_DB_MAX_IDLE=25

# HTTP Server — timeouts mas amplios para carga alta
HTTP_READ_TIMEOUT=60
HTTP_WRITE_TIMEOUT=60
HTTP_IDLE_TIMEOUT=120
