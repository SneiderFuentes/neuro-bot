# === Aplicación ===
PORT=8080
TZ=America/Bogota
LOG_LEVEL=info

# === Base de Datos Local (Docker MySQL) ===
DB_HOST=db
DB_PORT=3306
DB_DATABASE=neuro_bot
DB_USER=botuser
DB_PASSWORD=botpass
DB_ROOT_PASSWORD=secret

# === Base de Datos Externa (Centro Médico) ===
EXTERNAL_DB_HOST=host.docker.internal
EXTERNAL_DB_PORT=3306
EXTERNAL_DB_DATABASE=datosipsndx
EXTERNAL_DB_USER=
EXTERNAL_DB_PASSWORD=

# === Selección de implementación de BD externa (R-ARQ-01) ===
EXTERNAL_DB_DRIVER=datosipsndx

# === Bird API (WhatsApp) ===
BIRD_API_KEY_WA=
BIRD_ACCESS_KEY_ID=
BIRD_WEBHOOK_SECRET=
# Opcional: clave diferente para webhook outbound (si no se define, usa BIRD_WEBHOOK_SECRET)
#BIRD_WEBHOOK_SECRET_OUTBOUND=
BIRD_WORKSPACE_ID=b41653d6-85ab-462b-9fa9-8f95cab7f35b

# === Bird Canales WhatsApp ===
# Producción: +57 300 9139842 (WA Business ID: 788458530717605)
#BIRD_CHANNEL_ID=61a8f3cc-ba98-5181-899f-39e66653eeda
# Pruebas: +57 8 2795066 (WA Business ID: 1358104258788761)
BIRD_CHANNEL_ID=dacc4070-7e4a-59fd-9b32-826010f1ab39

# API URL se construye con workspace + channel (actualizar al cambiar canal)
BIRD_API_URL=https://api.bird.com/workspaces/b41653d6-85ab-462b-9fa9-8f95cab7f35b/channels/dacc4070-7e4a-59fd-9b32-826010f1ab39

# === Bird Templates (usan canal de producción) ===
BIRD_CHANNEL_ID_TEMPLATES=61a8f3cc-ba98-5181-899f-39e66653eeda
BIRD_TEMPLATE_CONFIRM_PROJECT_ID=9815e890-b7a3-4b8d-93e3-10f54a338501
BIRD_TEMPLATE_CONFIRM_VERSION_ID=b41d2e90-35ff-410a-ba4c-11e4d8393d70
BIRD_TEMPLATE_CONFIRM_LOCALE=es-MX
BIRD_TEMPLATE_RESCHEDULE_PROJECT_ID=2f543596-4b47-439a-a396-c47ac283cbe3
BIRD_TEMPLATE_RESCHEDULE_VERSION_ID=08c45bb9-f5da-4de2-86a8-e4109f96a5ee
BIRD_TEMPLATE_RESCHEDULE_LOCALE=es-CO
BIRD_TEMPLATE_WAITING_LIST_PROJECT_ID=
BIRD_TEMPLATE_WAITING_LIST_VERSION_ID=
BIRD_TEMPLATE_WAITING_LIST_LOCALE=es-CO
BIRD_TEMPLATE_CANCELLATION_PROJECT_ID=
BIRD_TEMPLATE_CANCELLATION_VERSION_ID=
BIRD_TEMPLATE_CANCELLATION_LOCALE=es-CO

# === Bird Equipos por Servicio ===
# Grupo A: Ecografías, Rayos X, Resonancia, TAC (3 agentes)
BIRD_TEAM_GRUPO_A=75346eb4-15ed-4b61-aa98-6e74c2ddf6cb
# Grupo B: Neurología, Fisiatría, Estudios del sueño (2 agentes)
BIRD_TEAM_GRUPO_B=c25b8a25-4b96-4388-b6cb-741b6b452eb1
# Call Center: Fallback general (5 agentes)
BIRD_TEAM_FALLBACK=8db88508-a013-4c8a-a229-12a77fe1b244
# Agente fallback: si asignación a equipo falla, asignar directo a líder Call Center
BIRD_AGENT_FALLBACK=92cfad53-0442-48b7-92f4-fe660b11fd5f

# === Bird Voice (IVR) ===
BIRD_API_KEY_VOICE=
BIRD_VOICE_FLOW_ID=07ff3d7b-7fd9-4da5-bfe0-e059e9e06ea1

# === OpenAI (OCR de órdenes médicas) ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === Sesiones ===
SESSION_TIMEOUT_MINUTES=120

# === Inactividad (minutos sin respuesta del paciente) ===
INACTIVITY_REMINDER_1_MIN=5
INACTIVITY_REMINDER_2_MIN=15
INACTIVITY_CLOSE_MIN=30

# === Reintentos ===
# Intentos inválidos antes de mostrar menú de fallback (default: 4)
MAX_RETRIES=4

# === Centro Médico ===
CENTER_KEY=datosipsndx
CENTER_NAME=Neuro Electrodiagnóstico del Llano
BOT_NAME=Samuel

# === Seguridad ===
INTERNAL_API_KEY=

# === Ngrok ===
NGROK_AUTHTOKEN=
# Producción:
#NGROK_HOSTNAME=app.colibrixa.com
# Pruebas:
NGROK_HOSTNAME=endodermal-prearticulate-teodora.ngrok-free.dev

# === Docker Health Watcher (alertas Telegram) ===
TG_BOT_TOKEN=
TG_CHAT_IDS=
